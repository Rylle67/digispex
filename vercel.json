{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/login",    "dest": "/api/index.js" },
    { "src": "/register", "dest": "/api/index.js" },
    { "src": "/admin",    "dest": "/api/index.js" },
    { "src": "/owner",    "dest": "/api/index.js" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}
